# Telegram 推播設定
# 1. 在 Telegram 搜尋 @BotFather，建立 bot 取得 token
# 2. 將 bot 加入群組或開啟私訊，取得 chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Line Notify 推播設定
# 至 https://notify-bot.line.me/zh_TW/ 申請 token
LINE_NOTIFY_TOKEN=

# 優惠篩選門檻（可依需求調整）
MIN_CASHBACK_PCT=5       # 最低現金回饋 %（預設 5%）
MIN_DISCOUNT_PCT=20      # 最低折扣 %（預設 8折 = 20%）
MIN_POINTS_MULTIPLIER=3  # 最低點數倍率（預設 3倍）

# 爬蟲設定
PLAYWRIGHT_HEADLESS=true
SCRAPE_TIMEOUT_MS=30000
